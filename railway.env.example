# Railway Dashboard → Service → Variables
# İlk deploy: PostgreSQL + Redis ekle → DATABASE_URL / REDIS_URL otomatik gelir.
# Volume ekle → Mount Path: /data/media

NODE_ENV=production
TRUST_PROXY=1

# Zorunlu — ilk ve tek admin bu değerlerle oluşturulur (deploy öncesi doldurun)
# SESSION_SECRET: openssl rand -hex 32
SESSION_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=
# İsteğe bağlı görünen ad
ADMIN_FULL_NAME=Sistem Yöneticisi

# PostgreSQL eklentisi (otomatik — elle yazmayın)
# DATABASE_URL=

# Redis eklentisi (önerilir)
# REDIS_URL=

MEDIA_DIR=/data/media
MAX_MEDIA_BYTES=33554432
MEDIA_MAX_AGE_DAYS=0
AUDIT_LOG_MAX=0
MAX_BACKUPS=0
PRUNE_ORPHAN_MEDIA=0
PERSIST_SECRETS_IN_STORE=0

CLOUD_API_GRAPH_VERSION=v21.0
CLOUD_API_ACCESS_TOKEN=
CLOUD_API_PHONE_NUMBER_ID=
CLOUD_API_WABA_ID=
CLOUD_API_WEBHOOK_VERIFY_TOKEN=
CLOUD_API_APP_SECRET=
REQUIRE_WEBHOOK_SIGNATURE=1