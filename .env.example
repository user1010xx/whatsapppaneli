# Yerel geliştirme — kopyalayın: cp .env.example .env
# İlk admin yalnızca bu değerlerle oluşturulur; test kullanıcısı eklenmez.

PORT=3000
NODE_ENV=development
SESSION_SECRET=degistirin-guclu-bir-deger
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Degistirin1
ADMIN_FULL_NAME=Sistem Yöneticisi
TRUST_PROXY=false

# PostgreSQL (set edilirse JSON yerine kalıcı DB; Railway'de zorunlu)
# DATABASE_URL=postgresql://user:pass@host:5432/railway
# REDIS_URL=redis://default:pass@host:6379

DATA_FILE=./data/app.json
MEDIA_DIR=./data/media
MAX_MEDIA_BYTES=33554432
MEDIA_MAX_AGE_DAYS=90
AUDIT_LOG_MAX=5000
MAX_BACKUPS=20
PRUNE_ORPHAN_MEDIA=1
PERSIST_SECRETS_IN_STORE=1

CLOUD_API_BASE_URL=https://graph.facebook.com/v21.0
CLOUD_API_GRAPH_VERSION=v21.0
CLOUD_API_ACCESS_TOKEN=
CLOUD_API_PHONE_NUMBER_ID=
CLOUD_API_WABA_ID=
CLOUD_API_WEBHOOK_VERIFY_TOKEN=
CLOUD_API_APP_SECRET=
CLOUD_API_SKIP_HEALTH_PING=false
REQUIRE_WEBHOOK_SIGNATURE=

DEFAULT_COUNTRY_CODE=90